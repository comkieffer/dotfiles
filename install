#! /usr/bin/env python3

from pathlib import Path

from installer.config import ProgramConfig, Recommends, Version
from installer.run import install_dotfiles

REQUIRED_DIRS = [
    "~/.config/",
    "~/.local/share",
    "~/.local/bin",
]

STOWED_PROGRAMS: dict[str, ProgramConfig] = {
    "fish": ProgramConfig(
        # We use `fisher` to install plugins, this will put the installed functions in
        # `functions`. This is also where we put our own functions. If we do not create
        # the directory, all of the plugin-installed functions will appear in our diff.
        create_dirs=[
            "~/.config/fish/completions/",
            "~/.config/fish/conf.d/",
            "~/.config/fish/functions/",
        ],
        # Ensure that the list of plugins is up-to-date
        post_install=["fish -c 'fisher update'"],
        recommended_binaries=[
            Recommends("atuin"),
            Recommends("bat", ("/usr/bin/batcat",)),
            Recommends("direnv"),
            Recommends("exa"),
            Recommends("fzf"),
            Recommends("hx", ("/usr/bin/helix",)),
            Recommends("jq"),
            Recommends("starship"),
            Recommends("zoxide"),
        ],
    ),
    "git": ProgramConfig(
        recommended_binaries=[
            Recommends("difftastic", binary="difft"),
            Recommends("diffr"),
            Recommends("delta"),
            Recommends("lazygit"),
            Recommends("mergiraf"),
        ]
    ),
    "gdb": ProgramConfig(),
    "helix": ProgramConfig(
        executable="hx",
    ),
    "matlab": ProgramConfig(),
    "vim": ProgramConfig(),
    "sublime-text-3": ProgramConfig(
        executable="subl",
        create_dirs=["~/.config/sublime-text-3/Packages/User"],
    ),
    "sublime-merge": ProgramConfig(
        executable="smerge",
        create_dirs=["~/.config/sublime-merge/Packages/User"],
    ),
    "regolith": ProgramConfig(
        executable="regolith-look",
        create_dirs=["~/.config/regolith3"],
    ),
    "vscode": ProgramConfig(
        executable="code",
        create_dirs=["~/.config/Code/User"],
    ),
    "tools": ProgramConfig(
        executable="pipx",
        create_dirs=["~/.local/share/reminders"],
        recommended_binaries=[
            Recommends("poetry", min_version=Version.from_string("2.0.0")),
            Recommends("uv"),
            Recommends("just", min_version=Version.from_string("1.30.0")),
        ],
    ),
}

repo_root = Path(__file__).resolve().parent
assert (repo_root / ".git").is_dir()

if __name__ == "__main__":
    install_dotfiles(REQUIRED_DIRS, STOWED_PROGRAMS, repo_root)

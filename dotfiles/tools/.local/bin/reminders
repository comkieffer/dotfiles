#!/usr/bin/env python3

"""
Motd of the local user.

Show messages stored in XDG_USER_DATA_DIR / reminders. The first non-empty line of the
file is the title, the rest of the file is the reminder body. Empty lines between the
title and the body are ignored. Empty lines in the body are preserved.

If ``rich`` is installed, it is used to print the reminders so rich markup may be used
in the file.

# Authoring content

Content is written in rich markup [0] (think old fashion forum formatting codes). If
the ``rich`` library is installed, it is used to render the markup, otherwise, the tags
are stripped, and no formatting is applied.

To better suit the use case, some pseudo markup is applied:

- Lines starting with ``$`` are console commands, the ``$`` receives special formatting.
- ``#`` comments (from ``#`` to end of line) are automatically dimmed.
- Pseudo-style tags are expanded before rendering:
  - ``[prgm] ... [/prgm]`` → bold (program name)
  - ``[arg] ... [/arg]`` → cyan (flag or argument name)
  - ``[arg-value] ... [/arg-value]`` → yellow (argument value)

Use color codes directly to format content.

- Avoid using ``[bold]`` unless you absolutely want to draw attention to a phrase
- Use `cyan` to make content stand out.
- Use `magenta` for content that should be more muted (but not invisible)
- Use `dim` for comments

[0]: https://rich.readthedocs.io/en/stable/markup.html
"""

import argparse
import random
import re
import shutil
import sys
from contextlib import suppress
from pathlib import Path
from typing import TextIO

try:
    import platformdirs  # type: ignore[import-not-found]

    HAS_PLATFORMDIRS = True
except ImportError:
    HAS_PLATFORMDIRS = False

try:
    from rich.console import Console  # type: ignore[import-not-found]
    from rich.errors import MarkupError  # type: ignore[import-not-found]
    from rich.padding import Padding  # type: ignore[import-not-found]
    from rich.panel import Panel  # type: ignore[import-not-found]

    HAS_RICH = True
except ImportError:
    HAS_RICH = False

PROGNAME = Path(__file__).name

if HAS_PLATFORMDIRS:
    REMINDERS_DIR = platformdirs.user_data_path(PROGNAME)
else:
    REMINDERS_DIR = Path.home() / ".local" / "share" / PROGNAME


# --- Parse Reminder File -----------------------------------------------------


def consume_directives(f: TextIO) -> dict[str, str]:
    """Read % directive lines from the top of the file, leaving f positioned at the title."""
    directives: dict[str, str] = {}
    while True:
        pos = f.tell()
        line = f.readline()
        if not line:
            break
        stripped = line.strip()
        if stripped.startswith("%"):
            content = stripped[1:].strip()
            key, _, value = content.partition(":")
            directives[key.strip()] = value.strip()
        else:
            f.seek(pos)
            break
    return directives


def read_non_empty_line(f: TextIO) -> str:
    while line := f.readline():
        if line.strip():
            return line
    return ""


# --- Directives --------------------------------------------------------------


def _cond_executable(name: str) -> bool:
    return shutil.which(name.strip()) is not None


_CONDITION_FUNCTIONS = {
    "executable": _cond_executable,
}


def evaluate_condition(condition: str) -> bool:
    match = re.fullmatch(r"(\w+)\(([^)]*)\)", condition.strip())
    if not match:
        print(f"Warning: unrecognised condition syntax: {condition!r}", file=sys.stderr)
        return True
    func_name, arg = match.group(1), match.group(2)
    fn = _CONDITION_FUNCTIONS.get(func_name)
    if fn is None:
        print(f"Warning: unknown condition function: {func_name!r}", file=sys.stderr)
        return True
    return fn(arg)


def check_directives(directives: dict[str, str]) -> bool:
    """Return False if any directive says the reminder should be skipped."""
    if "if" in directives:
        return evaluate_condition(directives["if"])
    return True


# --- Display Reminder --------------------------------------------------------


def strip_rich_tags(text: str) -> str:
    """Remove Rich markup tags like [bold], [red], [/bold], etc."""
    return re.sub(r"\[/?[^\]]+\]", "", text)


PSEUDO_STYLES = {
    "prgm": "bold",
    "arg": "cyan",
    "arg-value": "yellow",
}


def expand_pseudo_styles(text: str) -> str:
    for pseudo, rich_style in PSEUDO_STYLES.items():
        text = text.replace(f"[{pseudo}]", f"[{rich_style}]")
        text = text.replace(f"[/{pseudo}]", f"[/{rich_style}]")
    return text


def format_comments(text: str) -> str:
    # (?<!\[) — don't match # inside Rich color tags like [#ff0000]
    # \s+     — require whitespace before #, so standalone "# heading" lines are left alone
    # #[^\n]* — the # and everything to end of line (whitespace included in match to preserve spacing)
    return re.sub(r"(?<!\[)\s+#[^\n]*", lambda m: f"[dim]{m.group()}[/dim]", text)


def format_shell_lines(text: str) -> str:
    lines = text.split("\n")
    return "\n".join(
        "[bold green]$[/bold green]" + line[1:] if line.startswith("$") else line
        for line in lines
    )


def show_reminder(path: Path) -> None:
    with path.open("r") as f:
        consume_directives(f)
        reminder_title = read_non_empty_line(f)
        reminder_contents = read_non_empty_line(f) + "\n" + f.read().strip("\n")

    reminder_contents = expand_pseudo_styles(
        format_shell_lines(format_comments(reminder_contents))
    )

    if HAS_RICH:
        console = Console()
        try:
            panel = Panel(
                reminder_contents, title=f"[bold]{reminder_title}[/]", padding=1
            )
            padded_panel = Padding(panel, (1, 1))
            console.print(padded_panel)
        except MarkupError as e:
            print(f"Markup error in {path.name}: {e}", file=sys.stderr)
    else:
        clean_title = strip_rich_tags(reminder_title)
        clean_contents = strip_rich_tags(reminder_contents)
        print(clean_title + "\n\n" + clean_contents)


# --- Entry Point -------------------------------------------------------------


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Display reminder messages from the reminders directory"
    )
    parser.add_argument(
        "file",
        nargs="?",
        help="Specific reminder file to show (optional, shows random if not specified)",
    )
    return parser.parse_args()


def main() -> None:
    args = parse_args()

    if not REMINDERS_DIR.is_dir():
        sys.exit(0)

    reminder_files = [f for f in REMINDERS_DIR.iterdir() if f.is_file()]
    if not reminder_files:
        print(f"No reminders found in '{REMINDERS_DIR}'.")
        sys.exit(0)

    if args.file:
        file_as_path = Path(args.file)
        if file_as_path.exists():
            selected = file_as_path
        else:
            selected = REMINDERS_DIR / args.file
            if not selected.is_file():
                print(f"Error: Reminder file '{args.file}' not found", file=sys.stderr)
                sys.exit(1)

        # If we pass in the file directly, do not check the directives
        with selected.open("r") as f:
            _ = consume_directives(f)
            show_reminder(selected)

        sys.exit(0)

    # No file argument, we need to pick one to display.
    for candidate in random.sample(reminder_files, len(reminder_files)):
        with candidate.open("r") as f:
            directives = consume_directives(f)
        if check_directives(directives):
            show_reminder(candidate)
            sys.exit(0)

    print("No reminder files can be shown.")
    sys.exit(0)


if __name__ == "__main__":
    with suppress(KeyboardInterrupt):
        main()

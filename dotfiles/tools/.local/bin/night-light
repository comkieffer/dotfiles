#!/usr/bin/env python3
"""Manage gammastep (Wayland night light)."""

import subprocess
import sys

import click
from rich import print as rprint


def run(args: list[str], check: bool = True) -> subprocess.CompletedProcess:
    """Run command and return result."""
    try:
        result = subprocess.run(args, capture_output=True, text=True, check=check)
        return result
    except subprocess.CalledProcessError as e:
        rprint(f"[bold red]Error:[/bold red] Command failed: {e}")
        if e.stderr:
            rprint(f"[dim]{e.stderr.strip()}[/dim]")
        sys.exit(1)
    except FileNotFoundError:
        rprint(f"[bold red]Error:[/bold red] {args[0]} not found")
        sys.exit(1)


def is_active() -> bool:
    """Check if gammastep service is active."""
    result = run(["systemctl", "--user", "is-active", "gammastep"], check=False)
    return result.returncode == 0


def start_service() -> None:
    """Start gammastep service."""
    run(["systemctl", "--user", "start", "gammastep"])


def stop_service() -> None:
    """Stop gammastep service."""
    run(["systemctl", "--user", "stop", "gammastep"])


@click.group(invoke_without_command=True)
@click.pass_context
def main(ctx):
    """Manage gammastep night light settings."""
    if ctx.invoked_subcommand is None:
        # Default to toggle if no command provided
        ctx.invoke(toggle)


@main.command()
def toggle():
    """Toggle night light on/off."""
    if is_active():
        stop_service()
        rprint("Night light [bold yellow]disabled[/bold yellow]")
    else:
        start_service()
        rprint("Night light [bold green]enabled[/bold green]")


@main.command()
def status():
    """Show current night light status."""
    subprocess.run(["systemctl", "--user", "status", "gammastep"])


@main.command("set-temperature")
@click.argument("temperature", type=int)
def set_temperature(temperature):
    """Set night light color temperature (1000-10000K).

    This restarts the service with a one-shot temperature override.
    To persist, edit ~/.config/gammastep/config.ini
    """
    # Validate range
    if not 1000 <= temperature <= 10000:
        rprint(
            "[bold red]Error:[/bold red] Temperature must be between 1000 and 10000K"
        )
        sys.exit(1)

    # Stop the service
    if is_active():
        stop_service()

    # Start with one-shot temperature
    try:
        subprocess.Popen(
            ["gammastep", "-O", str(temperature)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
        rprint(f"Temperature set to [cyan]{temperature}[/cyan]K (one-shot mode)")
        rprint(
            "[dim]Service stopped. Run 'toggle-night-light toggle' to restart normal mode.[/dim]"
        )
    except Exception as e:
        rprint(f"[bold red]Error:[/bold red] Failed to set temperature: {e}")
        sys.exit(1)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        rprint("\n[dim]Cancelled[/dim]")
        sys.exit(130)

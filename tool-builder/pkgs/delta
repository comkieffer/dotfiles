name="delta"
version="0.19.2"

download() {
    fetch_or_clone \
        --repo    "https://github.com/dandavison/delta" \
        --tag     "$version" \
        --src-dir "$(src_dir "$name")"
}

build() {
    build_with_rust \
        --src "$(src_dir "$name")" \
        --out "$(bin_dir)/$name"
}

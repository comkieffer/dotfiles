name="atuin"
version="v18.16.1"

download() {
    fetch_or_clone \
        --repo    "https://github.com/atuinsh/atuin.git" \
        --tag     "$version" \
        --src-dir "$(src_dir "$name")"
}

build() {
    build_with_rust \
        --src "$(src_dir "$name")" \
        --out "$(bin_dir)/$name"
}

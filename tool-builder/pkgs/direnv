name="direnv"
version="v2.36.0"

download() {
    fetch_or_clone \
        --repo    "https://github.com/direnv/direnv.git" \
        --tag     "$version" \
        --src-dir "$(src_dir "$name")"
}

build() {
    build_with_go \
        --src     "$(src_dir "$name")" \
        --out     "$(bin_dir)/$name" \
        --ldflags "-X main.version=$version"
}

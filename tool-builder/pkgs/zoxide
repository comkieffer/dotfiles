name="zoxide"
version="v0.9.9"

download() {
    fetch_or_clone \
        --repo    "https://github.com/ajeetdsouza/zoxide" \
        --tag     "$version" \
        --src-dir "$(src_dir "$name")"
}

build() {
    build_with_rust \
        --src "$(src_dir "$name")" \
        --out "$(bin_dir)/$name"
}

name="difft"
version="0.69.0"

download() {
    fetch_or_clone \
        --repo    "https://github.com/wilfred/difftastic" \
        --tag     "$version" \
        --src-dir "$(src_dir "$name")"
}

build() {
    build_with_rust \
        --src "$(src_dir "$name")" \
        --out "$(bin_dir)/$name"
}

#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/stdlib
source "$(dirname "${BASH_SOURCE[0]}")/lib/stdlib"

action="build"
pkg_file=

while [[ $# -gt 0 ]]; do
    case "$1" in
        --version) action="version"; shift ;;
        --*) echo "Unknown flag: $1" >&2; exit 1 ;;
        *)   pkg_file="$1"; shift ;;
    esac
done

if [[ -z "$pkg_file" ]]; then
    echo "Usage: $(basename "$0") [--version] <pkg-file>" >&2
    exit 1
fi

if [[ ! -f "$pkg_file" ]]; then
    echo "error: pkg file not found: $pkg_file" >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$pkg_file"

case "$action" in
    version) echo "$version" ;;
    build)   build ;;
esac

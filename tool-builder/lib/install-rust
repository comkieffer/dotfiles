#!/usr/bin/env bash
set -euo pipefail

RUST_VERSION="1.95.0"

# shellcheck source=tool-builder/lib/stdlib
source "$(dirname "${BASH_SOURCE[0]}")/stdlib"

detect_arch

# shellcheck disable=SC2155
export RUSTUP_HOME="$(build_dir)/rustup"
RUSTUP_BIN="$CARGO_HOME/bin/rustup"

# shellcheck disable=SC2155
export CARGO_HOME="$(build_dir)/cargo"
CARGO_BIN="$CARGO_HOME/bin/cargo"

echo "==> install-rust: target $RUSTUP_HOME (Rust $RUST_VERSION, $ARCH)"

if [[ -x "$RUSTUP_BIN" ]]; then
    installed="$("$CARGO_BIN" --version | grep -oP '\K[0-9]+\.[0-9]+\.[0-9]+')"
    if [[ "$installed" == "$RUST_VERSION" ]]; then
        echo "==> Rust $RUST_VERSION already installed"
    else
        echo "==> Upgrading Rust $installed -> $RUST_VERSION"
        "$RUSTUP_BIN" toolchain install "$RUST_VERSION"
        "$RUSTUP_BIN" default "$RUST_VERSION"
    fi
else
    rustup_init_url="https://static.rust-lang.org/rustup/dist/${ARCH}-unknown-linux-gnu/rustup-init"

    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT

    echo "==> Downloading rustup-init"
    curl -fsSL "$rustup_init_url" -o "$tmpdir/rustup-init"
    chmod +x "$tmpdir/rustup-init"

    echo "==> Installing Rust $RUST_VERSION"
    "$tmpdir/rustup-init" \
        --no-modify-path \
        --default-toolchain "$RUST_VERSION" \
        -y

    # rustup-init may skip setting the default when a system rustup is present (e.g. Arch)
    "$RUSTUP_BIN" default "$RUST_VERSION"
fi

echo "==> Done: $("$CARGO_BIN" --version)"

#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/stdlib
source "$(dirname "${BASH_SOURCE[0]}")/stdlib"

detect_arch
export RUSTUP_HOME="$(build_dir)/rustup"
export CARGO_HOME="$(build_dir)/cargo"
CARGO_BIN="$CARGO_HOME/bin/cargo"
TARGET="${ARCH}-unknown-linux-musl"

repo= version= src_dir= out_file=

while [[ $# -gt 0 ]]; do
    case "$1" in
        --repo)    repo="$2";     shift 2 ;;
        --version) version="$2";  shift 2 ;;
        --src)     src_dir="$2";  shift 2 ;;
        --out)     out_file="$2"; shift 2 ;;
        *) echo "Unknown flag: $1" >&2; exit 1 ;;
    esac
done

src_dir="${src_dir:-$(src_dir "$(basename "$repo" .git)")}"
bin_name="$(basename "$out_file")"

echo "==> build-rust: $out_file (version $version, $TARGET)"

if [[ ! -x "$CARGO_BIN" ]]; then
    echo "==> Cargo not found, running install-rust"
    "$TOOL_BUILDER_DIR/lib/install-rust"
fi

fetch_or_clone "$repo" "$version" "$src_dir"

echo "==> Building"
"$CARGO_BIN" build \
    --manifest-path "$src_dir/Cargo.toml" \
    --release \
    --target "$TARGET" \
    --bin "$bin_name"

echo "==> Copying binary"
mkdir -p "$(dirname "$out_file")"
cp "$src_dir/target/$TARGET/release/$bin_name" "$out_file"

echo "==> Done: $(file "$out_file")"

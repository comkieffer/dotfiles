#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/stdlib
source "$(dirname "${BASH_SOURCE[0]}")/stdlib"

GO_BIN="$(build_dir)/go/bin/go"

repo= version= src_dir= out_file= ldflags=

while [[ $# -gt 0 ]]; do
    case "$1" in
        --repo)    repo="$2";     shift 2 ;;
        --version) version="$2";  shift 2 ;;
        --src)     src_dir="$2";  shift 2 ;;
        --out)     out_file="$2"; shift 2 ;;
        --ldflags) ldflags="$2";  shift 2 ;;
        *) echo "Unknown flag: $1" >&2; exit 1 ;;
    esac
done

src_dir="${src_dir:-$(src_dir "$(basename "$repo" .git)")}"

echo "==> build-go: $out_file (version $version)"

if [[ ! -x "$GO_BIN" ]]; then
    echo "==> Go not found, running install-go"
    "$TOOL_BUILDER_DIR/lib/install-go"
fi

fetch_or_clone "$repo" "$version" "$src_dir"

echo "==> Building"
mkdir -p "$(dirname "$out_file")"
CGO_ENABLED=0 "$GO_BIN" build \
    -C "$src_dir" \
    -trimpath \
    -ldflags="-s -w $ldflags" \
    -o "$out_file" \
    .

echo "==> Done: $(file "$out_file")"

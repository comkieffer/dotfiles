{
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,

    "editor.rulers": [ 80, 100, ],

    "workbench.colorTheme": "Default Light Modern",

    // Disable preview mode,
    // When you single-click on a file, it is opened in preview mode. If you
    // click another file, it is opened in the same tab. With this disabled,
    // each file is opened in a dedicated tab.
    "workbench.editor.enablePreview": false,

    // Do not require confirmation for drag-and-drop file moves
    "explorer.confirmDragAndDrop": false,

    // Close copilot chat panel by default
    "workbench.secondarySideBar.defaultVisibility": "hidden"
    "claudeCode.preferredLocation": "panel",

    //
    // Language-specific Settings
    //

    "[python]": {
        "editor.rulers": [ 88, ]
    }

    "[restructuredtext]": {
        "editor.wordWrap": "bounded",
        "editor.wordWrapColumn": 100,
        "editor.wrapOnEscapedLineFeeds": false
    },

}
